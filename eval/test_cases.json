{
  "description": "供应链异常检测评测用例 — 50 个手工标注样本。anomaly=true 为真实异常，false 为正常样本。归因答案仅对 anomaly=true 的样本提供。",
  "created": "2026-05-21",
  "version": "1.0",
  "test_cases": [
    {
      "id": "TC001",
      "type": "anomaly",
      "description": "极端亏损+延迟复合：利润 -$277.09，延迟 2 天，品类 Fishing 利润率极薄（品类均值 0.08 vs 全局 0.12），Late delivery 状态。这是最经典的延迟触发运费补贴导致亏损的模式。",
      "expected": {
        "is_anomaly": true,
        "primary_metric": "Benefit per order",
        "severity": "high",
        "root_cause_keywords": ["延迟", "运费", "补贴", "亏损"],
        "action_keywords": ["财务", "费用明细", "折扣", "复核"]
      },
      "data_snapshot": {
        "Order Id": 77202,
        "Benefit per order": -277.09,
        "shipping_delay_days": 2,
        "Order Item Profit Ratio": -1.65,
        "Delivery Status": "Late delivery",
        "Category Name": "Fishing",
        "Market": "LATAM",
        "Order Region": "South America"
      }
    },
    {
      "id": "TC002",
      "type": "anomaly",
      "description": "单品类结构性延迟：Men's Footwear 品类延迟 4 天，品类近 7 天均值 0.68 天（全局 0.46 天，高出 48%）。Standard Class 运输。延迟幅度远超品类和运输方式的正常波动，可能为仓库操作异常。",
      "expected": {
        "is_anomaly": true,
        "primary_metric": "shipping_delay_days",
        "severity": "high",
        "root_cause_keywords": ["结构性延迟", "品类", "仓库", "拣货", "SKU"],
        "action_keywords": ["出库", "货位", "扫描", "品类"]
      },
      "data_snapshot": {
        "Order Id": 75939,
        "shipping_delay_days": 4,
        "Benefit per order": 31.52,
        "Order Item Profit Ratio": 0.21,
        "Delivery Status": "Late delivery",
        "Category Name": "Men's Footwear",
        "Shipping Mode": "Standard Class",
        "Market": "LATAM"
      }
    },
    {
      "id": "TC003",
      "type": "anomaly",
      "description": "利润率异常偏高：订单利润率 0.47，品类 Cardio Equipment 近 7 天利润率均值仅 0.08（全局 0.12），该订单高出品类均值近 6 倍。最可能是成本数据缺失或定价错误。",
      "expected": {
        "is_anomaly": true,
        "primary_metric": "Order Item Profit Ratio",
        "severity": "low",
        "root_cause_keywords": ["成本数据", "定价", "采购", "缺失"],
        "action_keywords": ["核查", "售价", "成本", "定价"]
      },
      "data_snapshot": {
        "Order Id": 1360,
        "Order Item Profit Ratio": 0.47,
        "Benefit per order": 327.75,
        "shipping_delay_days": 0,
        "Delivery Status": "Shipping on time",
        "Category Name": "Cardio Equipment",
        "Customer Segment": "Consumer",
        "Order Item Total": 327.75
      }
    },
    {
      "id": "TC004",
      "type": "anomaly",
      "description": "延迟+亏损复合（跟 TC001 同模式不同数据）：Women's Apparel，利润 -$358.12，延迟 3 天，Late delivery。品类近 7 天均值 -$0.12（全局 $0.12），说明该品类本身利润空间极薄。",
      "expected": {
        "is_anomaly": true,
        "primary_metric": "Benefit per order",
        "severity": "high",
        "root_cause_keywords": ["延迟", "运费", "品类利润", "亏损"],
